# Exemplo com login SQL Server
DATABASE_URL=mssql+pyodbc://@localhost/TemTudo?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes
INITIAL_STOCK_DEFAULT=100

# Exemplo com autenticacao Windows, se preferir:
# DATABASE_URL=mssql+pyodbc://@localhost:1433/TemTudo?driver=ODBC+Driver+18+for+SQL+Server&Trusted_Connection=yes&TrustServerCertificate=yes

# Para bater com o seu SQL original, os produtos novos entram com estoque inicial 100.
# Em um sistema real, normalmente esse valor seria 0 e a entrada viria pelo fornecedor.
INITIAL_STOCK_DEFAULT=100
